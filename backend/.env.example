DATABASE_URL="postgresql://taskearn_user:taskearn_dev_pw@localhost:5432/taskearn_db?schema=public"

PORT=4000
NODE_ENV=development

JWT_SECRET=dev_change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# File upload limits
MAX_UPLOAD_SIZE_MB=5

# CPA / Offerwall network integration (fill in once approved by a network)
CPA_POSTBACK_SECRET=dev_change_this_secret

# Future payment gateway API keys (EasyPaisa / JazzCash merchant APIs) - leave blank until you have merchant accounts
EASYPAISA_MERCHANT_ID=
EASYPAISA_API_KEY=
JAZZCASH_MERCHANT_ID=
JAZZCASH_API_KEY=
